# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=nodecms

# JWT 密钥（请替换为随机生成的强密钥）
JWT_SECRET=replace_with_a_strong_random_string

# CORS 允许的前端域名
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 百炼 DashScope API 配置
BAILIAN_API_KEY=your_api_key_here
BAILIAN_MODEL=qwen-turbo
